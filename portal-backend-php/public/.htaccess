# Em producao (ver deploy/GUIA_SMOKE_DEPLOY.md), src/ e config.php ficam fora
# do web root -- descomente e ajuste o caminho abaixo. Em dev local (php -S)
# nao precisa: index.php cai no padrao (um nivel acima deste arquivo).
# SetEnv APP_BASE_PATH /home/SEU_USUARIO/domains/financialreports.com.br/app

# Front controller unico: tudo que nao for um arquivo existente cai no
# index.php, que roteia via src/Router.php.
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.php [QSA,L]

# Nunca servir config.php nem nada fora de public/ (defesa extra -- em
# producao config.php ja fica fora do web root, ver PLANO.md "Deploy").
<Files "config.php">
    Require all denied
</Files>
