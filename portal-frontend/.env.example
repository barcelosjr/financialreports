# URL base da API. Vazio = mesma origem (proxy do Vite em dev, mesmo
# domínio em produção). Só preencha se a API estiver em outro host.
VITE_API_URL=

# API key de desenvolvimento -- precisa existir em CLIENTS no
# portal-backend-php/config.php (copie de config.php.example).
VITE_API_KEY=troque-por-uma-chave-aleatoria-longa

# Flags de migração mock -> backend real, uma por costura (ver PLANO.md).
# true = usa a API; false = mantém o mock local.
VITE_USE_BACKEND_ESTRUTURA=false
VITE_USE_BACKEND_TENANT=false
VITE_USE_BACKEND_SESSAO=false
VITE_USE_BACKEND_FINANCEIRO=false
