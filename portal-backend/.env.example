# Azure AD (Entra ID) - Service Principal (Client Credentials Flow)
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=

# Power BI - workspace (group) e dataset do modelo semantico
GROUP_ID=
DATASET_ID=

# Cache de resultados das queries DAX (segundos). Ver README para recomendacoes por endpoint.
CACHE_TTL_SECONDS=600

# Porta HTTP do servidor
PORT=3000

# Modo mock (opcional): quando "true", o backend nao chama o Azure AD nem o Power BI.
# Usa os dados ficticios documentados no README para desenvolvimento local sem credenciais reais.
MOCK_MODE=false

# Caminho do arquivo com as API keys por cliente e as empresas que cada uma pode
# consultar. Copie clients.example.json para clients.json e preencha com dados reais
# -- o arquivo real nunca deve ser commitado (ja esta no .gitignore).
CLIENTS_CONFIG_PATH=./clients.json

# Origem(ns) permitidas para CORS (separadas por virgula se mais de uma).
# Deixe em branco enquanto o dominio do frontend nao estiver definido (CORS
# fica desabilitado). Ex: CORS_ORIGIN=https://portal.suaempresa.com.br
# Use "*" apenas em desenvolvimento.
CORS_ORIGIN=

# Caminho do arquivo com as classificacoes de conta contabil por empresa (DRE/
# Balanco/Fluxo de Caixa), configuradas na pagina de administracao. Criado
# automaticamente na primeira classificacao salva -- nao precisa existir de
# antemao, e o arquivo real nunca deve ser commitado (ja esta no .gitignore).
CLASSIFICACOES_CONFIG_PATH=./classificacoes.json

# Caminho do arquivo com a estrutura (hierarquia de grupos/subgrupos) de cada
# relatorio (DRE/Balanco/Fluxo de Caixa) por empresa, configurada na pagina
# estrutura.html. Criado automaticamente no primeiro grupo salvo -- nao
# precisa existir de antemao, e o arquivo real nunca deve ser commitado (ja
# esta no .gitignore).
ESTRUTURAS_CONFIG_PATH=./estruturas.json
