# Azure AD (Entra ID) - Service Principal (Client Credentials Flow)
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=

# Power BI - workspace (group) e dataset do modelo semantico
GROUP_ID=
DATASET_ID=

# Cache de resultados das queries DAX (segundos). Ver README para recomendacoes por endpoint.
CACHE_TTL_SECONDS=600

# Porta HTTP do servidor
PORT=3000

# Modo mock (opcional): quando "true", o backend nao chama o Azure AD nem o Power BI.
# Usa os dados ficticios documentados no README para desenvolvimento local sem credenciais reais.
MOCK_MODE=false
